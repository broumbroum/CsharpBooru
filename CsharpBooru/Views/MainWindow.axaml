<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        xmlns:rootvm="using:CsharpBooru.ViewModels"

        x:Class="CsharpBooru.Views.MainWindow"
        x:DataType="rootvm:MainWindowViewModel"
        Icon="/Resources/Logo/Logo.ico" Title="C#Booru"
        MinWidth="450" MinHeight="600">

    <Panel> 
        <!-- Start page -->
        <Panel x:Name="FirstStart">
            <TextBlock 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                Text="Select an existing folder or a new folder to create the Booru."/>
            <Button
			    HorizontalAlignment= "Center"
                Margin="0 50 0 0"
			    Click="SelectFolder">
                Select a Folder
            </Button>
        </Panel>
        <!-- Main page -->
        <DockPanel x:Name="Start">
            <ContentControl Content="{Binding TopBar}" DockPanel.Dock="Top"/>
            <ContentControl Content="{Binding CurrentPage}" Margin="0,10,0,0" DockPanel.Dock="Bottom"/>
        </DockPanel> 
    </Panel>

</Window>
