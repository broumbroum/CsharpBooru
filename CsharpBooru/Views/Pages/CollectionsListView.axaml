<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="CsharpBooru.Views.Pages.CollectionsListView">
	
	<ScrollViewer VerticalScrollBarVisibility="Auto">
		<StackPanel Orientation="Vertical">

			<WrapPanel x:Name="PaginationTopPanel" 
						HorizontalAlignment="Center"
						Orientation="Horizontal"/>

			<Grid ColumnDefinitions="100, *" ColumnSpacing="10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="20,0,20,0">
				<Button Grid.Column="0" Width="100" Click="OnAddCollectionClicked">
					<TextBlock Text="Add" HorizontalAlignment="Center"/>
				</Button>
				<TextBox x:Name="NewCollectionTextBox" Grid.Column="1" PlaceholderText="Name new collection" TextWrapping="Wrap" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
			</Grid>

			<StackPanel x:Name="CollectionsPanel"/>

			<WrapPanel x:Name="PaginationBottomPanel" 
						HorizontalAlignment="Center"
						Orientation="Horizontal"/>
		</StackPanel>
	</ScrollViewer>

</UserControl>
