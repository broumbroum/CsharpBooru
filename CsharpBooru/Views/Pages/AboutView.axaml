<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="CsharpBooru.Views.Pages.AboutView">

	<StackPanel>
		<TextBlock Margin="5" HorizontalAlignment="Center" Text="CsharpBooru" FontSize="20" FontWeight="Bold"/>
		
		<TextBlock Margin="5" HorizontalAlignment="Center" Text="License : LGPL-3.0 license"/>

		<Button Margin="5" HorizontalAlignment="Center" Click="OpenGitHub">
			<TextBlock Text="GitHub Repository : broumbroum/CsharpBooru"/>
		</Button>

		<TextBlock Margin="5" HorizontalAlignment="Center" Text="Libraries used :"  FontWeight="Bold"/>

		<Button Margin="5" HorizontalAlignment="Center" Click="OpenAvalonia">
			<TextBlock Text="Avalonia UI"/>
		</Button>
		<Button Margin="5" HorizontalAlignment="Center" Click="OpenLibVLC">
			<TextBlock Text="LibVLCSharp"/>
		</Button>
		<Button Margin="5" HorizontalAlignment="Center" Click="OpenReactiveUI">
			<TextBlock Text="ReactiveUI"/>
		</Button>
		<Button Margin="5" HorizontalAlignment="Center" Click="OpenSkiaSharp">
			<TextBlock Text="SkiaSharp"/>
		</Button>

		<TextBlock Margin="5" HorizontalAlignment="Center" Text="Graphics used :"  FontWeight="Bold"/>
		
		<Button Margin="5" HorizontalAlignment="Center" Click="OpenIcones8">
			<TextBlock Text="Icones8.fr"/>
		</Button>

	</StackPanel>

</UserControl>

